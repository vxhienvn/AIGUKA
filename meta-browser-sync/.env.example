# Supabase
SUPABASE_ENABLED=true
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta Browser Sync
META_BUSINESS_INBOX_URL=https://business.facebook.com/latest/inbox/all
META_SYNC_HEADLESS=false
META_SYNC_MAX_CONVERSATIONS=50
META_SYNC_SLOW_MS=700
META_SYNC_PAGE_ID=

# Optional fallback mapping if Meta UI cannot expose ad id/name reliably
# Format: ad name keyword => ad_id|ad_name, one per line can be put into meta-browser-sync/ad-map.json instead.
